# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="Your API Key"

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Your Gmail address
SMTP_EMAIL="fof27330@gmail.com"
# App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD="your app password"
# SMTP settings (defaults work for Gmail)
SMTP_HOST="host link"
SMTP_PORT="port no."

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ─── AI Rate Limiting ─────────────────────────────────────────────────────────
# Max analyses per authenticated user within each time window.
# Increase or decrease based on your Gemini API quota and budget.
RATE_LIMIT_PER_HOUR="5"
RATE_LIMIT_PER_DAY="20"

# ─── Search API (Company & Competitor Research) ───────────────────────────
# SerpAPI key for web search (replaces blocked Google scraping on cloud)
# Get from: https://serpapi.com/manage-api-key
SERPAPI_KEY="your-serpapi-key"
